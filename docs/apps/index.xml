 font-size: 15px;
 line-height: 1.55;
 }
 .mcp-demo .mcp-row {
 display: flex;
 gap: 14px;
 margin-bottom: 22px;
 }
 .mcp-demo .mcp-row:last-child { margin-bottom: 0; }
 .mcp-demo .mcp-av {
 width: 28px; height: 28px;
 border-radius: 50%;
 flex-shrink: 0;
 display: flex; align-items: center; justify-content: center;
 font-size: 12px; font-weight: 600; color: #fff;
 }
 .mcp-demo .mcp-av.user { background: #6b4eb8; }
 .mcp-demo .mcp-av.bot { background: #1a1a1a; }
 .mcp-demo .mcp-body { flex: 1; min-width: 0; padding-top: 3px; }
 .mcp-demo .mcp-who {
 font-weight: 600; font-size: 13.5px; margin-bottom: 4px;
 }
 .mcp-demo .mcp-body p { margin: 0 0 10px; }
 .mcp-demo .mcp-body code {
 background: #f0f0f0; padding: 2px 6px; border-radius: 4px;
 font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
 font-size: 13px;
 }
 .mcp-demo .mcp-body pre {
 background: #f0f0f0; padding: 10px 12px; border-radius: 6px;
 font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
 font-size: 12.5px; overflow-x: auto; margin: 0 0 10px;
 }
 .mcp-demo .mcp-tool {
 background: #fafafa;
 border: 1px solid var(--border);
 border-radius: 8px;
 padding: 8px 12px;
 margin: 6px 0 12px;
 display: flex; align-items: center; gap: 10px;
 font-size: 13px;
 }
 .mcp-demo .mcp-tool-icon {
 width: 20px; height: 20px; border-radius: 4px;
 background: #25d366; color: #fff;
 display: flex; align-items: center; justify-content: center;
 font-size: 11px; font-weight: 700; flex-shrink: 0;
 }
 .mcp-demo .mcp-tool-name {
 font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
 color: var(--accent); font-size: 12.5px;
 }
 .mcp-demo .mcp-tool-meta {
 margin-left: auto; color: var(--text-muted); font-size: 12px;
 }
 .mcp-demo .mcp-body h4 {
 font-size: 14px; font-weight: 600; margin: 14px 0 6px;
 }
 .mcp-demo .mcp-body ul { margin: 0 0 10px; padding-left: 20px; }
 .mcp-demo .mcp-body ul li { margin-bottom: 4px; }
 .mcp-demo .mcp-body strong { font-weight: 600; }
&lt;/style>

