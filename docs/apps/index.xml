 --accent: #10a37f;

 max-width: 720px;
 margin: 1.5rem auto;
 padding: 20px 24px;
 background: #ffffff;
 border: 1px solid var(--border);
 border-radius: 12px;
 font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
